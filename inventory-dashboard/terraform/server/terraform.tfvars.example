# Copy to terraform.tfvars (local use) or configure as Spacelift environment variables.
# In Spacelift set variables as TF_VAR_<name> = <value>.
# Mark sensitive values (external_id) as secret in Spacelift.

# ── Required ─────────────────────────────────────────────────────────────────
server_account_id  = "123456789012"   # dcli_sharedsvcs2 account ID
frontend_bucket_name = "dcli-inventory-dashboard-frontend-dev"

# Comma-separated: "111122223333:DevAccount,444455556666:ProdAccount"
inventory_accounts = ""

# ── Optional ─────────────────────────────────────────────────────────────────
aws_region   = "us-east-1"
environment  = "dev"
project_name = "inventory-dashboard"

inventory_role_name = "InventoryReadRole"
# external_id       = ""   # set as secret in Spacelift

# WAF IP allowlist (default allows only 107.138.107.196)
# allowed_ip_cidrs = ["107.138.107.196/32"]

# Custom domain (optional)
# custom_domain_name  = "dashboard.dcli.com"
# acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/..."

refresh_schedule_expression = "cron(0 */6 * * ? *)"
log_retention_days          = 30
